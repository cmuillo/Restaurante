# ==============================================
# RESTAURANTE — Variables de Entorno Backend
# Copiar a .env y completar los valores reales
# ==============================================

# Entorno
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DATABASE_URL=postgresql://restaurante:secret@localhost:5432/restaurante

# JWT
JWT_SECRET=cambia-este-secreto-muy-largo-y-seguro
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# CORS — URLs del frontend y kiosco separadas por coma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Almacenamiento de imágenes (opcional — usar S3 o ruta local)
STORAGE_DRIVER=local
# STORAGE_S3_BUCKET=mi-bucket
# STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ==============================================
# FACTURACIÓN ELECTRÓNICA — HACIENDA CR
# ==============================================

# URL base de la API de Comprobantes Electrónicos
# Sandbox:    https://api-sandbox.comprobanteselectronicos.go.cr/recepcion/v1
# Producción: https://api.comprobanteselectronicos.go.cr/recepcion/v1
HACIENDA_API_URL=https://api-sandbox.comprobanteselectronicos.go.cr/recepcion/v1

# URL del IDP de Hacienda para obtener el token OAuth2
# Sandbox:    https://idp.comprobanteselectronicos.go.cr/auth/realms/rut-stag/protocol/openid-connect/token
# Producción: https://idp.comprobanteselectronicos.go.cr/auth/realms/rut/protocol/openid-connect/token
HACIENDA_IDP_URL=https://idp.comprobanteselectronicos.go.cr/auth/realms/rut-stag/protocol/openid-connect/token

# Credenciales ATV del contribuyente (cuenta en atv.hacienda.go.cr)
HACIENDA_CLIENT_ID=api-stag
HACIENDA_USERNAME=tu_usuario_atv@cedula
HACIENDA_PASSWORD=tu_contrasena_atv

# Datos del emisor (el restaurante / contribuyente)
# Tipo: 01=física  02=jurídica  03=DIMEX  04=NITE
HACIENDA_ISSUER_TAX_ID=3101123456
HACIENDA_ISSUER_TAX_ID_TYPE=02

# Ubicación del emisor (códigos de Hacienda)
HACIENDA_PROVINCE=01
HACIENDA_CANTON=01
HACIENDA_DISTRICT=01

# Códigos para numero consecutivo
HACIENDA_BRANCH_CODE=001
HACIENDA_TERMINAL_CODE=00001

# Ruta al archivo .p12 de Firma Digital (BCCR)
# Se obtiene en cualquier banco autorizado (BCR, BAC, BN, etc.) — es gratuito
HACIENDA_P12_PATH=/ruta/al/certificado.p12
HACIENDA_P12_PASSWORD=contrasena_del_p12


# Correo electrónico (opcional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@restaurante.com
