# ==============================================
# RESTAURANTE — Variables de Entorno Backend
# Copiar a .env y completar los valores reales
# ==============================================

# Entorno
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DATABASE_URL=postgresql://restaurante:secret@localhost:5432/restaurante

# JWT
JWT_SECRET=cambia-este-secreto-muy-largo-y-seguro
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# CORS — URLs del frontend y kiosco separadas por coma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Almacenamiento de imágenes (opcional — usar S3 o ruta local)
STORAGE_DRIVER=local
# STORAGE_S3_BUCKET=mi-bucket
# STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Correo electrónico (opcional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@restaurante.com
